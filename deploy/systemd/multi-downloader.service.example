[Unit]
Description=multi-downloader backend
After=network.target

[Service]
Type=simple
User=REPLACE_USER
WorkingDirectory=/home/REPLACE_USER/Documents/GitHub/multi-downloader
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /home/REPLACE_USER/Documents/GitHub/multi-downloader/server.cjs
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
